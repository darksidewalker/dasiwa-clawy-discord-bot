# ── Discord ───────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token-here

# ── Ollama ────────────────────────────────────────────────────────────
# Where your Ollama instance is running.
#
# If running locally (not Docker):
#   OLLAMA_URL=http://localhost:11434
#
# If running in Docker and Ollama is on the HOST machine:
#   Linux/Mac (Docker Desktop):
#   OLLAMA_URL=http://host.docker.internal:11434
#
#   Linux (native Docker, no Docker Desktop):
#   OLLAMA_URL=http://172.17.0.1:11434
#   (172.17.0.1 is the default docker0 bridge IP — run `ip route` to confirm)
#
#   Or use the host's LAN IP directly:
#   OLLAMA_URL=http://192.168.1.x:11434
#
OLLAMA_URL=http://host.docker.internal:11434
