# ── Discord (required) ────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token-here

# ── Ollama ────────────────────────────────────────────────────────────
# Where your Ollama instance is running.
#
# If running locally (not Docker):
#   OLLAMA_URL=http://localhost:11434
#
# If running in Docker and Ollama is on the HOST machine:
#   Linux/Mac (Docker Desktop):
#   OLLAMA_URL=http://host.docker.internal:11434
#
#   Linux (native Docker, no Docker Desktop):
#   OLLAMA_URL=http://172.17.0.1:11434
#   (172.17.0.1 is the default docker0 bridge IP — run `ip route` to confirm)
#
#   Or use the host's LAN IP directly:
#   OLLAMA_URL=http://192.168.1.x:11434
#
OLLAMA_URL=http://host.docker.internal:11434

# ── Optional: configure the bot without editing config.yaml ──────────
# Any of these, if set, override the matching values in config/config.yaml
# on container startup. Useful for Docker / TrueNAS deployments where you
# want one canonical source of config (this file or the compose env block).
#
# Leave commented to use the values from config/config.yaml.
#
# Your Discord server ID (right-click server → Copy Server ID).
# GUILD_ID=0
#
# Your personal Discord user ID (right-click your name → Copy User ID).
# OWNER_ID=0
#
# Private channel ID for moderation logs. 0 = disabled.
# LOG_CHANNEL_ID=0
#
# Bot mode: moderate_only | chat_and_moderate | chat_only
# BOT_MODE=chat_and_moderate
#
# Override the Ollama model from config.yaml:
# OLLAMA_MODEL=qwen3:8b
