# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtual environment (not needed — Docker installs its own)
.venv/
venv/
env/

# Data and config (mounted as volumes at runtime — not baked in)
data/
# config/ is included so the Dockerfile can bake in defaults.
# The actual runtime config is always mounted as a volume and overrides these.
# Secrets (.env) are excluded separately below — never in config/.
config/blocklist.json

# Secrets — NEVER bake these into an image
.env
*.env

# Development / local tools
.git/
.gitignore
*.md
AGENTS.md
QUICKSTART.md

# Installer and start scripts (not needed inside the container)
install.bat
install.sh
start.bat
start.sh

# Docker files themselves (avoid recursive context)
Dockerfile
docker-compose.yml
.dockerignore

# Editor artifacts
.vscode/
.idea/
*.swp
*.swo
